# ─── Backend API ──────────────────────────────────────────────────────────────
# URL of the Go backend — used by server components and build
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080

# ─── AWS Cognito ──────────────────────────────────────────────────────────────
# These are server-side only (no NEXT_PUBLIC_ prefix) — never exposed to browser
COGNITO_REGION=us-east-1
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=your_cognito_app_client_id
# COGNITO_CLIENT_SECRET is NOT needed if the app client has no secret configured
# COGNITO_CLIENT_SECRET=your_cognito_client_secret

# Full hosted UI base URL, e.g. https://your-domain.auth.us-east-1.amazoncognito.com
COGNITO_DOMAIN=https://your-domain.auth.us-east-1.amazoncognito.com

# Must match the callback URL registered in Cognito App Client settings
COGNITO_REDIRECT_URI=http://localhost:3000/auth/callback

# Must match the logout URL registered in Cognito App Client settings
COGNITO_LOGOUT_REDIRECT_URI=http://localhost:3000/login

# ─── Playwright E2E (optional — only needed for test:e2e) ────────────────────
TEST_EMAIL=test@example.com
TEST_PASSWORD=TestPassword123!
